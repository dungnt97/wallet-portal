# Admin API environment variables
# Copy to .env and fill in values for local development.
# NEVER commit .env to git.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: docker run -d --name wp-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16-alpine
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wallet_portal

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Service-to-service auth (D4) ─────────────────────────────────────────────
# Shared bearer token for internal /internal/* routes.
# Rotate quarterly. Generate: openssl rand -hex 32
SVC_BEARER_TOKEN=changeme-generate-with-openssl-rand-hex-32

# ── Google Workspace OIDC (D3) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_WORKSPACE_DOMAIN=company.com

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
