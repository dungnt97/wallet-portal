# Admin API environment variables
# Copy to .env and fill in values for local development.
# NEVER commit .env to git.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: docker run -d --name wp-pg-p03 -e POSTGRES_PASSWORD=postgres -p 5433:5432 postgres:16-alpine
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/wallet_portal

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Service-to-service auth (D4) ─────────────────────────────────────────────
# Shared bearer token for internal /internal/* routes.
# Rotate quarterly. Generate: openssl rand -hex 32
SVC_BEARER_TOKEN=changeme-generate-with-openssl-rand-hex-32

# ── Google Workspace OIDC (D3) ───────────────────────────────────────────────
# Create an OAuth 2.0 Web application client in Google Cloud Console.
# Authorised redirect URIs must include GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx
# Redirect URI must match the one registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
# Leave empty to allow any Google account; set to your domain (e.g. company.com)
# to enforce Workspace hd claim check (D3 — never hardcoded).
GOOGLE_WORKSPACE_DOMAIN=

# ── Session ──────────────────────────────────────────────────────────────────
# Must be 32+ random bytes. Generate: openssl rand -hex 32
SESSION_SECRET=change_me_32_chars_min_generate_with_openssl
SESSION_COOKIE_NAME=wp_session
SESSION_TTL_SECONDS=86400

# ── WebAuthn Relying Party ───────────────────────────────────────────────────
# Dev: rpId=localhost, origin=http://localhost:5173
# Prod: rpId=<your domain>, origin=https://<your domain>
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Wallet Portal
WEBAUTHN_ORIGIN=http://localhost:5173

# ── Dev helpers ──────────────────────────────────────────────────────────────
# Set AUTH_DEV_MODE=true to skip Google token verification (NEVER use in prod)
AUTH_DEV_MODE=false

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ── Chain integration (Slice 0) ───────────────────────────────────────────────
# BNB Chapel testnet Safe multisig (filled after infra/chain deploy)
SAFE_ADDRESS_BNB_TESTNET=
# Safe Transaction Service for BNB Chapel
SAFE_TX_SERVICE_URL=https://safe-transaction-bsc-testnet.safe.global
# Solana Devnet Squads multisig PDA (filled after infra/chain deploy)
SQUADS_MULTISIG_PDA_DEVNET=
SOLANA_DEVNET_RPC=https://api.devnet.solana.com
BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
