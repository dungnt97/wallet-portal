{
  "name": "@wp/admin-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:reset": "tsx src/db/reset.ts",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./db-schema": "./src/db/schema/index.ts"
  },
  "dependencies": {
    "@wp/shared-types": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.41.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@wp/config": "workspace:*",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5"
  }
}
