{
  "name": "@wp/admin-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./db-schema": "./src/db/schema/index.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/session": "^11.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@sentry/node": "^10.49.0",
    "@simplewebauthn/server": "^10",
    "@solana/web3.js": "^1.98.4",
    "@wp/shared-types": "workspace:*",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.16.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "ioredis": "^5.4.0",
    "jose": "^5",
    "nodemailer": "^8.0.5",
    "oauth4webapi": "^3",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@wp/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
