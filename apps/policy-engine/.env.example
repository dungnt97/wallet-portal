# policy-engine environment variables
# Copy to .env and populate before running locally.

# HTTP port the service listens on.
PORT=3003

# Postgres connection string (read-only role recommended for policy-engine).
DATABASE_URL=postgres://postgres:postgres@localhost:5433/postgres?sslmode=disable

# Shared bearer secret for service-to-service auth (Decision D4).
# Must match the value injected into admin-api and wallet-engine.
# Rotate quarterly; store in AWS Secrets Manager in production.
SVC_BEARER_TOKEN=changeme-dev-secret

# Log level: debug | info | warn | error
LOG_LEVEL=info
