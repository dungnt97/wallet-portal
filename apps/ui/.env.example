# Admin API base URL (used by gen:api-types script)
# Default: http://localhost:3001 (proxied via Vite /api → :3001)
ADMIN_API_URL=http://localhost:3001

# Vite dev server port override (default: 5173)
# VITE_PORT=5173

# ── Chain RPC endpoints ───────────────────────────────────────────────────────
VITE_BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
VITE_SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Get project ID from https://cloud.walletconnect.com
# Required for WalletConnect connector (also covers Ledger Connect Kit path)
VITE_WALLETCONNECT_PROJECT_ID=get-from-cloud.walletconnect.com

# ── Multisig contract addresses (filled after Phase 02 deploy) ────────────────
VITE_SAFE_ADDRESS_BNB_TESTNET=
VITE_SQUADS_MULTISIG_PDA_DEVNET=
