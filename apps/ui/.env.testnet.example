# Real-testnet e2e configuration
# Copy this file to .env.testnet and fill in values.
# NEVER commit .env.testnet — it contains private keys.
# In CI, set these as GitHub Secrets (see .github/workflows/e2e-testnet.yml).

# ── RPC Endpoints ─────────────────────────────────────────────────────────────
# BNB Chapel Testnet (chainId 97)
BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
# Fallback RPC if primary is rate-limited:
# BNB_TESTNET_RPC=https://data-seed-prebsc-2-s1.binance.org:8545
# BNB_TESTNET_RPC=https://bsc-testnet-rpc.publicnode.com

# Solana Devnet
SOL_DEVNET_RPC=https://api.devnet.solana.com

# ── Deployed Contract Addresses ───────────────────────────────────────────────
# From infra/chain deploy scripts — run once per environment.
# BNB Safe multisig (2-of-3): pnpm --filter infra/chain deploy:safe-bnb-testnet
SAFE_ADDRESS_BNB_TESTNET=0x...

# Squads multisig PDA (2-of-3): pnpm --filter infra/chain deploy:squads-devnet
SQUADS_MULTISIG_PDA_DEVNET=...

# Test token contracts: pnpm --filter infra/chain deploy:tokens
USDT_BNB_ADDRESS=0x...
USDC_SOL_MINT=...

# ── Test Wallet Credentials ───────────────────────────────────────────────────
# Deployer wallets — used to mint test tokens and fund addresses.
# Generate with: cast wallet new (BNB) or solana-keygen new (Solana)
# Fund BNB deployer at: https://testnet.bnbchain.org/faucet-smart

# BNB deployer private key (0x-prefixed hex, 32 bytes)
DEPLOYER_PRIVATE_KEY_BNB=0x...

# Solana deployer keypair (base64-encoded 64-byte secret key)
# Generate: solana-keygen new -o /tmp/deployer.json && base64 /tmp/deployer.json
DEPLOYER_KEYPAIR_SOL_BASE64=...

# ── Treasurer Wallets (for multi-sig approval tests) ─────────────────────────
# Treasurer-0 (first signer in 2-of-3 Safe)
TREASURER_PRIVATE_KEY_BNB_0=0x...

# Treasurer-1 (second signer — reaching 2-of-3 threshold triggers execution)
TREASURER_PRIVATE_KEY_BNB_1=0x...

# Treasurer-0 Solana keypair (for Squads approval)
TREASURER_KEYPAIR_SOL_0_BASE64=...

# Treasurer-1 Solana keypair
TREASURER_KEYPAIR_SOL_1_BASE64=...

# ── Service URLs (override defaults for non-standard port configs) ─────────────
# Admin-API base URL (default: http://localhost:3001)
# ADMIN_API_URL=http://localhost:3001

# UI base URL served by Vite dev server (default: http://localhost:5173)
# UI_BASE_URL=http://localhost:5173
