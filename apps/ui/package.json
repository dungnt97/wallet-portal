{
  "name": "@wp/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src",
    "gen:api-types": "tsx scripts/gen-api-types.ts",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:testnet": "playwright test --config playwright.testnet.config.ts",
    "test:e2e:testnet:debug": "playwright test --config playwright.testnet.config.ts --debug",
    "test:e2e:testnet:ui": "playwright test --config playwright.testnet.config.ts --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@safe-global/api-kit": "^3",
    "@safe-global/protocol-kit": "^5",
    "@sentry/browser": "^10.49.0",
    "@sentry/react": "^10.49.0",
    "@simplewebauthn/browser": "^10",
    "@solana/wallet-adapter-react": "^0.15",
    "@solana/wallet-adapter-react-ui": "^0.9",
    "@solana/wallet-adapter-wallets": "^0.19",
    "@solana/web3.js": "^1",
    "@sqds/multisig": "^2",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "@wp/shared-types": "workspace:*",
    "@wp/ui-kit": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^23.16.5",
    "i18next-browser-languagedetector": "^8.0.2",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.73.1",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.2.4",
    "viem": "^2",
    "wagmi": "^2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.10",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^2.1.6"
  }
}
