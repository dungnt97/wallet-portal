# Wallet Engine — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Server
PORT=3002
LOG_LEVEL=info
NODE_ENV=development

# Database (shared with admin-api in dev)
DATABASE_URL=postgresql://wpuser:wppassword@localhost:5432/wallet_portal

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# BNB RPC endpoints (comma-separated for pool — primary + optional fallback)
RPC_BNB_PRIMARY=https://data-seed-prebsc-1-s1.binance.org:8545
RPC_BNB_FALLBACK=https://data-seed-prebsc-2-s1.binance.org:8545

# Solana RPC endpoints
RPC_SOLANA_PRIMARY=https://api.devnet.solana.com
RPC_SOLANA_FALLBACK=https://api.devnet.solana.com

# Admin API (service-to-service)
ADMIN_API_BASE_URL=http://localhost:3001
# Must match SVC_BEARER_TOKEN in admin-api — 32+ bytes, rotated quarterly
SVC_BEARER_TOKEN=change-me-min-32-characters-long!!

# HD derivation — DEV FIXTURE ONLY
# Production: replace with HSM/KMS call (Phase 12+). NEVER use real funds.
HD_MASTER_XPUB_BNB=test test test test test test test test test test test junk
HD_MASTER_SEED_SOLANA=your-hex-encoded-seed-here

# Token contract addresses (BNB mainnet defaults — override for testnet)
USDT_BNB_ADDRESS=0x55d398326f99059fF775485246999027B3197955
USDC_BNB_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d

# Solana token mint addresses (mainnet defaults — override for devnet)
USDT_SOL_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB
USDC_SOL_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── Watcher tuning (Slice 3) ──────────────────────────────────────────────────
# Poll intervals
WATCHER_BNB_POLL_INTERVAL_MS=3000
WATCHER_SOLANA_POLL_INTERVAL_MS=2000
# Confirmation depth before crediting
WATCHER_BNB_CONFIRM_DEPTH=12
WATCHER_SOLANA_CONFIRM_DEPTH=32
# Set false to disable block watchers — prevents CI from hitting public RPC
WATCHER_ENABLED=false

# ── Chain integration (Slice 0) ───────────────────────────────────────────────
# BNB Chapel testnet Safe multisig (filled after infra/chain deploy)
SAFE_ADDRESS_BNB_TESTNET=
# Safe Transaction Service for BNB Chapel
SAFE_TX_SERVICE_URL=https://safe-transaction-bsc-testnet.safe.global
# Solana Devnet Squads multisig PDA (filled after infra/chain deploy)
SQUADS_MULTISIG_PDA_DEVNET=
SOLANA_DEVNET_RPC=https://api.devnet.solana.com
BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
