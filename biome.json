{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  },
  "files": {
    "ignore": [
      "**/dist/**",
      "apps/policy-engine/**",
      ".claude/**",
      ".opencode/**",
      "claude/**",
      "apps/*/scripts/**",
      "guide/**",
      "node_modules/**",
      "portable-manifest.json",
      "release-manifest.json",
      ".releaserc.cjs",
      ".commitlintrc.json",
      "apps/ui/src/styles/base.css",
      "apps/ui/src/styles/pro-dashboard.css",
      "apps/ui/src/styles/wallet-flow.css",
      "apps/ui/src/styles/missing.css"
    ]
  },
  "overrides": [
    {
      "include": ["infra/chain/scripts/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "include": ["apps/ui/src/**/*.tsx", "apps/ui/src/**/*.ts"],
      "linter": {
        "rules": {
          "a11y": {
            "useButtonType": "off",
            "useKeyWithClickEvents": "off",
            "noSvgWithoutTitle": "off",
            "useSemanticElements": "off",
            "useAriaPropsForRole": "off",
            "useAltText": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    }
  ]
}
