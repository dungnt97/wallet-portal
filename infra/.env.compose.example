# Example env file for docker-compose local stack.
# Copy to infra/.env.compose and fill in real values.
# NEVER commit .env.compose to git.

# ── Shared ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@postgres:5432/wallet_portal

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── admin-api ─────────────────────────────────────────────────────────────────
PORT=3001
SESSION_SECRET=dev-session-secret-min-32-chars-here!!
SVC_BEARER_TOKEN=dev-svc-bearer-token-min-16chars
CORS_ORIGIN=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
GOOGLE_WORKSPACE_DOMAIN=
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Wallet Portal
WEBAUTHN_ORIGIN=http://localhost:5173
AUTH_DEV_MODE=true

# ── wallet-engine ─────────────────────────────────────────────────────────────
# PORT=3002  (set per-service in compose env block)
RPC_BNB_PRIMARY=https://bsc-dataseed.binance.org/
RPC_SOLANA_PRIMARY=https://api.mainnet-beta.solana.com
HD_MASTER_XPUB_BNB=xpub_placeholder_replace_me
HD_MASTER_SEED_SOLANA=seed_placeholder_replace_me
USDT_BNB_ADDRESS=0x55d398326f99059fF775485246999027B3197955
USDC_BNB_ADDRESS=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
ADMIN_API_BASE_URL=http://admin-api:3001

# ── policy-engine ─────────────────────────────────────────────────────────────
# PORT=3003  (set per-service in compose env block)

# ── OpenTelemetry (set per-service in compose env block) ─────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector-base:4318
OTEL_SERVICE_NAME=unknown

# ── Sentry (optional — leave empty to disable) ────────────────────────────────
SENTRY_DSN=
