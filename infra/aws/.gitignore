# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files
*.tfplan
*.tfplan.*

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Sensitive variable files — use tfvars.example instead
*.auto.tfvars
# main.tfvars intentionally committed (no secrets — secrets go in Secrets Manager)

# Crash logs
crash.log
crash.*.log

# Override files (local dev only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc
