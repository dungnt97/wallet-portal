# infra/chain — deploy script environment variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── EVM (BNB Chapel) ──────────────────────────────────────────────────────────
# Private key of the deployer wallet (funded with tBNB from the faucet)
# Faucet: https://testnet.bnbchain.org/faucet-smart
# Generate: cast wallet new  OR  openssl rand -hex 32
DEPLOYER_PRIVATE_KEY=0xyour-funded-chapel-private-key-here

# Optional: override default public RPC
BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# Comma-separated list of exactly 3 treasurer wallet addresses (EVM checksummed)
# These become the Safe owners; 2-of-3 threshold is hard-coded in deploy script.
TREASURER_ADDRESSES=0xAddr1,0xAddr2,0xAddr3

# ── Solana Devnet ─────────────────────────────────────────────────────────────
# Path to a Solana keypair JSON file for the deployer
# Generate: solana-keygen new -o ~/.config/solana/deployer-devnet.json
DEPLOYER_KEYPAIR_PATH=~/.config/solana/deployer-devnet.json

# Optional: override default devnet RPC
SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# Comma-separated list of exactly 3 treasurer Solana public keys (base58)
# These become the Squads members; 2-of-3 threshold is hard-coded in deploy script.
TREASURER_PUBKEYS=PubKey1Base58,PubKey2Base58,PubKey3Base58
