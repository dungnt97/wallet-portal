# Safe Transaction Service — environment variables
# Copy to .env.safe-tx and fill in values before running safe-tx-service.compose.yml
#
# Generate DJANGO_SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_hex(50))"
#
# This file is safe to commit (no real secrets).
# .env.safe-tx (with real values) is git-ignored.

# ── Django ────────────────────────────────────────────────────────────────────

# Required: random 100-char hex string — keep secret in production
DJANGO_SECRET_KEY=change-me-generate-with-python3-secrets-token-hex-50

# Set to 1 for local dev; 0 for production
DEBUG=0

# Restrict in production; '*' is fine for local testnet use
DJANGO_ALLOWED_HOSTS=*

# ── Ethereum / Chapel RPC ─────────────────────────────────────────────────────

# Chapel testnet public RPC — replace with a private endpoint for reliability
ETHEREUM_NODE_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# BNB Chapel testnet chain ID
ETHEREUM_CHAIN_ID=97

# ── Indexer tuning ─────────────────────────────────────────────────────────────

# Optional: set to a recent Chapel block number to skip genesis-to-now indexing.
# Indexing from block 0 can take many hours on Chapel testnet.
# Find a recent block at: https://testnet.bscscan.com
# Example: START_BLOCK=45000000
# Leave empty to index from genesis (not recommended for fresh installs).
START_BLOCK=

# Number of blocks to process per indexer batch (lower = less RPC load)
ETH_REORG_BLOCKS=20
