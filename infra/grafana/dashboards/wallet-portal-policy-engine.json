{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Wallet Portal — policy-engine decision rate per rule, deny reasons, kill-switch state",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Kill-Switch State",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "green" }, "1": { "text": "ON", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "wallet_portal_kill_switch_enabled",
          "legendFormat": "Kill Switch",
          "refId": "A"
        }
      ],
      "title": "Kill-Switch State",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "wallet_portal_kill_switch_enabled",
          "legendFormat": "Kill Switch (1=enabled)",
          "refId": "A"
        }
      ],
      "title": "Kill-Switch State Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 4,
      "title": "Policy Decisions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(policy_decisions_total[5m])) by (rule, result)",
          "legendFormat": "{{ rule }} / {{ result }}",
          "refId": "A"
        }
      ],
      "title": "Decision Rate by Rule",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(policy_decisions_total{result=\"deny\"}[5m])) by (rule)",
          "legendFormat": "{{ rule }}",
          "refId": "A"
        }
      ],
      "title": "Deny Rate by Rule (top deny reasons)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "title": "Deny Reason Distribution (top 10)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "topk(10, sum(increase(policy_decisions_total{result=\"deny\"}[1h])) by (rule))",
          "legendFormat": "{{ rule }}",
          "refId": "A"
        }
      ],
      "title": "Top 10 Deny Rules (last 1h)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(policy_decisions_total{result=\"deny\"}[5m])) / sum(rate(policy_decisions_total[5m]))",
          "legendFormat": "overall deny rate",
          "refId": "A"
        }
      ],
      "title": "Overall Policy Deny Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 10,
      "title": "HTTP Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 11,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"policy-engine\"}[5m])) by (le, route))",
          "legendFormat": "p95 {{ route }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"policy-engine\"}[5m])) by (le, route))",
          "legendFormat": "p99 {{ route }}",
          "refId": "B"
        }
      ],
      "title": "Policy Check Latency p95/p99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 12,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{job=\"policy-engine\"}[1m])) by (route, status_code)",
          "legendFormat": "{{ route }} {{ status_code }}",
          "refId": "A"
        }
      ],
      "title": "Policy Engine Request Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["wallet-portal", "policy-engine"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Wallet Portal — Policy Engine",
  "uid": "wallet-portal-policy-engine",
  "version": 1
}
