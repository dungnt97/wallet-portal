{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Wallet Portal — worker heartbeat age, RPC probe health, block lag",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Worker Heartbeat",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 120 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "time() - worker_last_heartbeat_seconds",
          "legendFormat": "{{ worker }} age",
          "refId": "A"
        }
      ],
      "title": "Worker Heartbeat Age (seconds since last ping)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "time() - worker_last_heartbeat_seconds",
          "legendFormat": "{{ worker }}",
          "refId": "A"
        }
      ],
      "title": "Worker Heartbeat Age Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 4,
      "title": "RPC Probe Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [
        {
          "expr": "rate(rpc_probe_failures_total[5m]) / rate(rpc_probe_total[5m])",
          "legendFormat": "{{ chain }} failure rate",
          "refId": "A"
        }
      ],
      "title": "RPC Probe Failure Rate",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(rpc_probe_total[5m])",
          "legendFormat": "{{ chain }} probes/s",
          "refId": "A"
        },
        {
          "expr": "rate(rpc_probe_failures_total[5m])",
          "legendFormat": "{{ chain }} failures/s",
          "refId": "B"
        }
      ],
      "title": "RPC Probe Rate vs Failures",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 7,
      "title": "Block Watcher Lag",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "id": 8,
      "targets": [
        {
          "expr": "watcher_block_lag",
          "legendFormat": "{{ chain }} block lag",
          "refId": "A"
        }
      ],
      "title": "Block Watcher Lag (blocks behind head)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["wallet-portal", "workers", "rpc"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Wallet Portal — Worker Heartbeat",
  "uid": "wallet-portal-worker-heartbeat",
  "version": 1
}
